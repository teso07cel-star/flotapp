generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vehiculo {
  id                Int      @id @default(autoincrement())
  patente           String   @unique
  vtvVencimiento    DateTime?
  seguroVencimiento DateTime?
  proximoServiceKm  Int?
  proximoCambioCubiertasKm Int?
  activo            Boolean  @default(true)
  codigoAutorizacion String?
  registros         RegistroDiario[]
  gastos            Gasto[]
}

model Sucursal {
  id        Int      @id @default(autoincrement())
  nombre    String
  direccion String?
  registros RegistroDiario[]
}

model RegistroDiario {
  id              Int      @id @default(autoincrement())
  fecha           DateTime @default(now())
  kmActual        Int 

  novedades       String?
  novedadResuelta Boolean  @default(false)
  resolucion      String?
  nombreConductor String?
  vehiculoId      Int
  vehiculo        Vehiculo @relation(fields: [vehiculoId], references: [id])
  sucursales      Sucursal[]
}


model Gasto {
  id          Int      @id @default(autoincrement())
  fecha       DateTime @default(now())
  monto       Float
  descripcion String
  tipo        String
  vehiculoId  Int
  vehiculo    Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
}
