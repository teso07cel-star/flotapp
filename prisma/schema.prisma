generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Vehiculo {
  id                       Int              @id @default(autoincrement())
  patente                  String           @unique
  tipo                     String?
  activo                   Boolean          @default(true)
  vtvVencimiento           DateTime?
  seguroVencimiento        DateTime?
  proximoServiceKm         Int?
  proximoCambioCubiertasKm Int?
  codigoAutorizacion       String?
  gastos                   Gasto[]
  mantenimientos           Mantenimiento[]
  registros                RegistroDiario[]
}

model Chofer {
  id              Int      @id @default(autoincrement())
  nombre          String   @unique
  dni             String?
  patenteAsignada String?
  deviceId        String?
  activo          Boolean  @default(true)
}

model Autorizacion {
  id       Int      @id @default(autoincrement())
  choferId Int?
  tipo     String   // ej: "DEVICE_BIND"
  datos    String   // JSON text
  estado   String   @default("PENDIENTE") // PENDIENTE, APROBADA, RECHAZADA
  fecha    DateTime @default(now())
}

model Sucursal {
  id        Int              @id @default(autoincrement())
  nombre    String
  direccion String?
  registros RegistroDiario[] @relation("RegistroDiarioToSucursal")
}

model RegistroDiario {
  id               Int        @id @default(autoincrement())
  fecha            DateTime   @default(now())
  kmActual         Int?
  tipoReporte      String?
  nivelCombustible String?
  lugarGuarda      String?
  novedades        String?
  novedadResuelta  Boolean    @default(false)
  resolucion       String?
  nombreConductor  String?
  vehiculoId       Int?
  vehiculo         Vehiculo?  @relation(fields: [vehiculoId], references: [id])
  sucursales       Sucursal[] @relation("RegistroDiarioToSucursal")
}

model Gasto {
  id          Int      @id @default(autoincrement())
  fecha       DateTime @default(now())
  monto       Float
  descripcion String
  tipo        String
  vehiculoId  Int
  vehiculo    Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
}

model Mantenimiento {
  id           Int       @id @default(autoincrement())
  tipo         String
  detalle      String?
  fecha        DateTime  @default(now())
  proximoKm    Int?
  proximaFecha DateTime?
  completado   Boolean   @default(false)
  vehiculoId   Int
  vehiculo     Vehiculo  @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
}
