generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// CACHE BUSTER 1778013137020

model Vehiculo {
  id             Int              @id @default(autoincrement())
  patente        String           @unique
  tipo           String
  activo         Boolean          @default(true)
  gastos         Gasto[]
  mantenimientos Mantenimiento[]
  registros      RegistroDiario[]
}

model Chofer {
  id     Int    @id @default(autoincrement())
  nombre String 
}

model Autorizacion {
  id      Int      @id @default(autoincrement())
  nombre  String
  patente String
  estado  String   @default("PENDIENTE")
  fecha   DateTime @default(now())
}

model Sucursal {
  id        Int              @id @default(autoincrement())
  nombre    String           
  registros RegistroDiario[] @relation("RegistroDiarioToSucursal")
}

model RegistroDiario {
  id               Int        @id @default(autoincrement())
  fecha            DateTime   @default(now())
  kmActual         Int?
  tipoReporte      String?
  nivelCombustible String?
  lugarGuarda      String?
  novedades        String?
  novedadResuelta  Boolean    @default(false)
  resolucion       String?
  nombreConductor  String?
  vehiculoId       Int?
  vehiculo         Vehiculo?  @relation(fields: [vehiculoId], references: [id])
  sucursales       Sucursal[] @relation("RegistroDiarioToSucursal")
}

model Gasto {
  id          Int      @id @default(autoincrement())
  fecha       DateTime @default(now())
  monto       Float
  descripcion String
  tipo        String
  vehiculoId  Int
  vehiculo    Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
}

model Mantenimiento {
  id         Int      @id @default(autoincrement())
  tipo       String
  fecha      DateTime @default(now())
  kmAviso    Int
  kmProx     Int
  completado Boolean  @default(false)
  vehiculoId Int
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
}
