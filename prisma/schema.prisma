
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vehiculo {
  id                Int      @id @default(autoincrement())
  patente           String   @unique
  vtvVencimiento    DateTime?
  seguroVencimiento DateTime?
  proximoServiceKm  Int?
  proximoCambioCubiertasKm Int?
  activo            Boolean  @default(true)
  codigoAutorizacion String?
  registros         RegistroDiario[]
  gastos            Gasto[]
}

model Sucursal {
  id        Int      @id @default(autoincrement())
  nombre    String
  direccion String?
  registros RegistroDiario[] @relation("RegistroDiarioToSucursal")
}

model Chofer {
  id     Int    @id @default(autoincrement())
  nombre String @unique
}

model Autorizacion {
  id        Int      @id @default(autoincrement())
  fecha     DateTime @default(now())
  nombre    String
  patente   String
  estado    String   @default("PENDIENTE")
}

model RegistroDiario {
  id              Int      @id @default(autoincrement())
  fecha           DateTime @default(now())
  kmActual        Int? 
  kmTeoricos      Int      @default(0)
  kmModificado    Boolean  @default(false)
  tipoReporte     String?  // INICIO, STOP, CIERRE
  nivelCombustible String?
  lugarGuarda     String?
  novedades       String?
  novedadResuelta Boolean  @default(false)
  resolucion      String?
  nombreConductor String?
  vehiculoId      Int?
  vehiculo        Vehiculo? @relation(fields: [vehiculoId], references: [id])
  sucursales      Sucursal[] @relation("RegistroDiarioToSucursal")
}

model Gasto {
  id          Int      @id @default(autoincrement())
  fecha       DateTime @default(now())
  monto       Float
  descripcion String
  tipo        String
  vehiculoId  Int
  vehiculo    Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
}
