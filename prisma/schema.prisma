datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Vehiculo {
  id                      Int              @id @default(autoincrement())
  patente                 String           @unique
  vtvVencimiento          DateTime?
  seguroVencimiento       DateTime?
  proximoServiceKm        Int?
  ultimoCambioCubiertasKm Int?
  kmParaCambioCubiertas   Int?             @default(60000)
  activo                  Boolean          @default(true)
  registros               RegistroDiario[]
  gastos                  Gasto[]
}

model Chofer {
  id              Int              @id @default(autoincrement())
  nombre          String
  patenteAsignada String?
  registros       RegistroDiario[]
}

model Sucursal {
  id        Int              @id @default(autoincrement())
  nombre    String
  direccion String?
  registros RegistroDiario[] @relation("RegistroSucursales")
}

model RegistroDiario {
  id              Int        @id @default(autoincrement())
  fecha           DateTime   @default(now())
  kmActual        Int
  novedades       String?
  nombreConductor String?
  vehiculoId      Int
  vehiculo        Vehiculo   @relation(fields: [vehiculoId], references: [id])
  choferId        Int?
  chofer          Chofer?    @relation(fields: [choferId], references: [id])
  sucursales      Sucursal[] @relation("RegistroSucursales")
}

model Gasto {
  id          Int      @id @default(autoincrement())
  fecha       DateTime @default(now())
  monto       Float
  tipo        String
  descripcion String?
  vehiculoId  Int
  vehiculo    Vehiculo @relation(fields: [vehiculoId], references: [id])
}
